<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bulgium Premium"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unlock the full power of your money."
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- VIP Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1A1A1A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFD700"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GO PREMIUM"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱149.00 / month"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upgrade"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="20dp"
                    android:text="Upgrade Now"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#FFD700"
                    android:textColor="#1A1A1A"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Premium Perks List -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Exclusive Features"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <!-- Perk 1: Live Concierge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/stat_sys_phone_call"
                app:tint="@color/primary"
                android:padding="8dp"
                android:background="@drawable/baseline_add_circle_24"
                android:backgroundTint="#1A21C262"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live Financial Concierge"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personalized calls from our agents based on your habits."
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"/>
            </LinearLayout>
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="@color/textDisabled"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/light_gray"/>

        <!-- Perk 2: Advanced Export -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_save"
                app:tint="@color/primary"
                android:padding="8dp"
                android:background="@drawable/baseline_add_circle_24"
                android:backgroundTint="#1A21C262"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PDF &amp; CSV Export"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generate beautiful reports for your accountant."
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"/>
            </LinearLayout>
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="@color/textDisabled"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/light_gray"/>

        <!-- Perk 3: AI Prediction -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="@color/primary"
                android:padding="8dp"
                android:background="@drawable/baseline_add_circle_24"
                android:backgroundTint="#1A21C262"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Spending Predictor"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See where you'll be in 6 months."
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"/>
            </LinearLayout>
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="@color/textDisabled"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
