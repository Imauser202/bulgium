<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Active Goal View (Wrapped in a Container for easy switching) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_active_goal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Navigation -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#8D8D8D" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="tuition fee balance"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_back" />

        <ImageView
            android:id="@+id/btn_edit_goal"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_edit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <!-- Tabs -->
        <LinearLayout
            android:id="@+id/tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <TextView
                android:id="@+id/tv_tab_goal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="GOAL"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tab_records"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="RECORDS"
                android:textColor="@color/textSecondary" />
        </LinearLayout>

        <View
            android:id="@+id/tab_indicator_goal"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="@color/primary"
            app:layout_constraintEnd_toStartOf="@+id/guideline_mid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tabs" />

        <View
            android:id="@+id/tab_indicator_records"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="@color/primary"
            android:visibility="invisible"
            app:layout_constraintStart_toEndOf="@+id/guideline_mid"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tabs" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_mid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <!-- Goal View -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/layout_goal_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/tab_indicator_goal"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="32dp">

                <FrameLayout
                    android:id="@+id/circle_container"
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_marginTop="40dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Fixed Progress Circle -->
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        android:layout_gravity="center"
                        android:progress="0"
                        app:indicatorColor="@color/primary"
                        app:trackColor="@color/light_gray"
                        app:indicatorSize="260dp"
                        app:trackThickness="16dp"
                        app:trackCornerRadius="8dp" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_goal_image"
                        android:layout_width="210dp"
                        android:layout_height="210dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_logo"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Bulgium.Circle" />

                    <TextView
                        android:id="@+id/tv_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="25dp"
                        android:background="@drawable/bg_percent_badge"
                        android:backgroundTint="@color/primary"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="0%"
                        android:gravity="center"
                        android:textColor="@color/onPrimary"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:id="@+id/label_saved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="SAVED"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/circle_container" />

                <TextView
                    android:id="@+id/tv_saved_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱ 100.00"
                    android:textColor="@color/primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_saved" />

                <LinearLayout
                    android:id="@+id/info_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/tv_saved_amount">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REMAINING"
                            android:textColor="@color/textSecondary"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tv_remaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱ 4,900.00"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GOAL"
                            android:textColor="@color/textSecondary"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tv_goal_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱ 5,000.00"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddSavings"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:paddingHorizontal="32dp"
                    android:text="Add saving"
                    android:textAllCaps="false"
                    android:textColor="@color/onPrimary"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="24dp"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconTint="@color/onPrimary"
                    app:layout_constraintTop_toBottomOf="@id/info_row"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_target_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_date_chip"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Target on 03 Mar 2026"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/btnAddSavings"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Button to see completed goals -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_completed"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="View Completed Goals"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_target_date"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Records View -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_records_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tab_indicator_goal"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSavingsHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="16dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tv_empty_records"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No savings records yet"
                android:textColor="#8D8D8D"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Empty State View (Initially Gone) -->
    <include
        android:id="@+id/layout_empty_state"
        layout="@layout/fragment_savings_empty"
        android:visibility="gone" />

    <!-- Hall of Fame / Completed Goals View -->
    <include
        android:id="@+id/layout_completed_view"
        layout="@layout/layout_completed_goals_view"
        android:visibility="gone" />

    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
